{
  "name": "@vanduo-oss/hex-grid",
  "version": "1.1.0",
  "description": "Standalone VdHexGrid package for canvas-based hex grids",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./hex-math": {
      "import": "./dist/hex-math.js",
      "require": "./dist/hex-math.cjs",
      "default": "./dist/hex-math.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs",
      "default": "./dist/vue.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "llms.txt"
  ],
  "keywords": [
    "vanduo",
    "hex",
    "hex-grid",
    "canvas",
    "axial",
    "pathfinding"
  ],
  "license": "MIT",
  "author": "vanduo-oss",
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "homepage": "https://vanduo.dev/#docs/vd-hex",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanduo-oss/hex-grid"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build.js",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "openspec:validate": "openspec validate --all",
    "openspec:list": "openspec list",
    "openspec:update": "openspec update"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "vue": "^3.5.39"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}