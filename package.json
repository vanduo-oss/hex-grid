{
  "name": "@vanduo-oss/hex-grid",
  "version": "1.0.0",
  "description": "Standalone VdHexGrid package for canvas-based hex grids",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./hex-math": {
      "import": "./dist/hex-math.js",
      "require": "./dist/hex-math.cjs",
      "default": "./dist/hex-math.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "keywords": [
    "vanduo",
    "hex",
    "hex-grid",
    "canvas",
    "axial",
    "pathfinding"
  ],
  "license": "MIT",
  "author": "vanduo-oss",
  "homepage": "https://vanduo.dev/#docs/vd-hex",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanduo-oss/hex-grid"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build.js",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "@playwright/test": "^1.59.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@playwright/test"
    ]
  }
}